# App URL
 NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Disable showing Google Auth in the UI
NEXT_PUBLIC_GOOGLE_AUTH_DISABLED="false"

# Supabase Authentication - Need all 3, anon key for client side, service role for api routes 
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

## Stripe API 
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Shadow Journal dashboard pricing (Stripe recurring Price IDs)
NEXT_PUBLIC_STRIPE_PRICE_REFLECT=
NEXT_PUBLIC_STRIPE_PRICE_INITIATE=
# One-time: extra AI analysis (€2 — default price_1TEzGrLgnA1V8fpJoBa9vZro / prod_UDQ7XONd6jWcxg)
NEXT_PUBLIC_STRIPE_PRICE_EXTRA_ANALYSIS=
# Local Stripe CLI testing (forward events incl. checkout.session.completed, customer.subscription.*, invoice.paid)
STRIPE_WEBHOOK_SECRET=

# OpenAI (server-side only)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# LangGraph / Agents backend (recommended for richer RAG + tool behavior)
LANGGRAPH_API_URL=http://localhost:2024
LANGGRAPH_ASSISTANT_ID=agent

# Optional abuse/cost controls
AI_MONTHLY_TOKEN_LIMIT=250000
AI_MONTHLY_COST_LIMIT_USD=20

